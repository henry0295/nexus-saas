# ═════════════════════════════════════════════════════════════════════════════
# NexusSaaS — Configuración de Producción
# ═════════════════════════════════════════════════════════════════════════════
#
# IMPORTANTE: Este archivo es un EJEMPLO. 
# DO NOT usar directamente. El deploy.sh genera automáticamente las credenciales.
#
# Para desplegar, ejecutar:
#   curl -sL https://raw.githubusercontent.com/tu-org/nexus-saas/main/deploy.sh | sudo bash -s -- X.X.X.X
#
# Las siguientes variables serán GENERADAS AUTOMÁTICAMENTE por deploy.sh:
#   - APP_KEY (clave única de la aplicación)
#   - DB_PASSWORD (contraseña MySQL generada aleatoriamente)
#   - REDIS_PASSWORD (contraseña Redis generada aleatoriamente)
#
# ═════════════════════════════════════════════════════════════════════════════

# ─── Aplicación ─────────────────────────────────────────────────────────────
APP_NAME="NexusSaaS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_KEY=base64:GENERATED_AUTOMATICALLY

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

BCRYPT_ROUNDS=12

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── Base de Datos (MySQL en Docker) ────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nexus_saas
DB_USERNAME=nexus_user
DB_PASSWORD=GENERATED_AUTOMATICALLY
DB_ROOT_PASSWORD=GENERATED_AUTOMATICALLY

# ─── Sesiones (Redis) ───────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=redis

# ─── Broadcasting & Filesystem ──────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ─── Cache (Redis) ──────────────────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_URL=redis://:GENERATED_AUTOMATICALLY@redis:6379/1

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=GENERATED_AUTOMATICALLY
REDIS_PORT=6379

# ─── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.your-email-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@nexus-saas.com
MAIL_FROM_NAME=NexusSaaS

# ─── Docker Compose ─────────────────────────────────────────────────────────
DEPLOY_IP=192.168.1.100
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
TZ=America/Bogota

# ─── Inicio Automático ──────────────────────────────────────────────────────
# Si es true, ejecuta migraciones en el primer despliegue
# Después de PRIMER despliegue, cambiar a false para evitar re-migrations
SKIP_MIGRATIONS=false

# Si es true, ejecuta seeders (solo en primer despliegue)
# Contiene datos iniciales: pricing rules, superadmin, etc.
RUN_SEEDERS=false

# ═════════════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ═════════════════════════════════════════════════════════════════════════════
#
# 1. El deploy.sh REEMPLAZA este archivo automáticamente con valores seguros
#
# 2. Las credenciales se guardan en:
#    /opt/nexus-saas/credentials.txt (solo lectura)
#
# 3. Para actualizar configuración post-deploy:
#    cd /opt/nexus-saas
#    docker compose -f docker-compose.prod.yml exec -T php php artisan config:cache
#
# 4. Para cambiar contraseña de base de datos (AVANZADO):
#    - Editar .env con nueva credencial
#    - Detener servicios: docker compose -f docker-compose.prod.yml down
#    - Resetear MySQL: docker volume rm nexus-saas_mysql_data
#    - Reiniciar: docker compose -f docker-compose.prod.yml up -d
#
# ═════════════════════════════════════════════════════════════════════════════
