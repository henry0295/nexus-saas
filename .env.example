# ═════════════════════════════════════════════════════════════════════════════
# NexusSaaS — Configuración de Entorno
# ═════════════════════════════════════════════════════════════════════════════
# Para desarrollo local, copiar este archivo a .env y llenar los valores.
# Para producción, usar .env.production.example como referencia.

# ─── Aplicación ─────────────────────────────────────────────────────────────
APP_NAME="NexusSaaS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:YOUR_KEY_HERE_GENERATED_BY_php_artisan_key_generate

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

BCRYPT_ROUNDS=12

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de Datos (MySQL Local) ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexus_saas
DB_USERNAME=root
DB_PASSWORD=

# ─── Sesiones ───────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting & Filesystem ──────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ─── Cache (Database para desarrollo local) ────────────────────────────────
CACHE_DRIVER=database
# CACHE_PREFIX=

# ─── Redis (Opcional para desarrollo) ───────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@nexus-saas.com
MAIL_FROM_NAME=NexusSaaS
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
